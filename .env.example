DATABASE_URL=postgresql://stremio:stremio_dev@localhost:5466/stremio_ai_subs
# Set to 'true' for production databases that require SSL connections
DATABASE_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Set for production Redis instances (required in docker-compose.prod.yml)
REDIS_PASSWORD=
# Set to 'true' to enable TLS for Redis connections
REDIS_TLS=false

# S3 Storage (Backblaze B2)
S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# Optional: endpoint used in presigned URLs returned to clients.
# For B2, this is typically the same as S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
S3_REGION=eu-central-003
S3_ACCESS_KEY_ID=your-b2-key-id
S3_SECRET_ACCESS_KEY=your-b2-application-key
S3_BUCKET_NAME=GlobalSubs
# Set to 'true' only for MinIO/LocalStack (path-style URLs); B2/AWS use virtual-hosted style (false)
S3_FORCE_PATH_STYLE=false

# API
API_PORT=3011
API_HOST=0.0.0.0
JWT_SECRET=supersecretkey_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:3010

# OAuth — Google Sign-In
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=

# OAuth — Apple Sign-In
# Create a Service ID at: https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=

# Stripe — payment for credit bundles and subscriptions
# When set, purchases create Stripe Checkout Sessions; webhooks verify payments.
# When unset, the API runs in sandbox mode (credits added without payment).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PACK50=
STRIPE_PRICE_PACK100=
STRIPE_PRICE_UNLIMITED=
# Public details shown on customer bank/card statements (5–22 chars)
STRIPE_STATEMENT_DESCRIPTOR=
# Shortened descriptor for per-product statements (2–10 chars, optional)
STRIPE_SHORTENED_DESCRIPTOR=
# Customer support details shown on invoices and receipts
STRIPE_SUPPORT_PHONE=
STRIPE_SUPPORT_URL=

# PayPal — alternative payment method (optional)
# When set, PayPal buttons appear alongside Stripe/card checkout.
# Create a REST app at https://developer.paypal.com/dashboard/applications
# For subscriptions, create a Billing Plan and set PAYPAL_PLAN_UNLIMITED.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_UNLIMITED=
PAYPAL_MODE=sandbox

# Internal API (for testing/ops endpoints; not used by the Stremio addon)
# Requests must include header: X-Internal-Token: <token>
# BullMQ dashboard is available at: /api/internal/queues
# Browser-friendly auth: /api/internal/queues?token=<token> (sets an HttpOnly cookie)
INTERNAL_API_TOKEN=

# Workers
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-5.2
GOOGLE_API_KEY=your-google-key
DEEPL_API_KEY=your-deepl-key

# Scrapers (internal scheduled baseline subtitle fetch)
# Enable the scrapers service worker loop
SCRAPERS_ENABLED=1
# Enable the instance to register the repeatable tick job (only 1 instance should do this)
SCRAPERS_SCHEDULER_ENABLED=0
# Cron schedule for ticks (BullMQ repeat pattern)
SCRAPERS_CRON=*/15 * * * *
# Max scrape jobs dispatched per tick
SCRAPERS_TICK_BATCH=25
# Concurrency for scrape workers
SCRAPERS_CONCURRENCY=2

# Scrapers discovery
# - popular: seed scrape_requests from Cinemeta's top catalogs (recommended)
# - requests: seed scrape_requests only from in-flight translation_requests (legacy)
# - both: do both
SCRAPERS_DISCOVERY_MODE=popular
# Languages to prefetch baseline sources for (comma-separated ISO-639-1)
SCRAPERS_SOURCE_LANGS=en
# How many items to seed from Cinemeta top catalogs on each tick
SCRAPERS_POPULAR_MOVIES_COUNT=100
SCRAPERS_POPULAR_SERIES_COUNT=100
# For series, scrapers need an episode stremioId; default is pilot episode.
SCRAPERS_POPULAR_SERIES_EPISODE=1:1
# Optional UA override for Cinemeta discovery calls
SCRAPERS_USER_AGENT=GlobalSubs/1.0

# OpenSubtitles (required for addon auto-fetch of source subtitles)
# Choose ONE:
# - REST v1: set OPENSUBTITLES_API_KEY
# - XML-RPC: set OPENSUBTITLES_XMLRPC_USERAGENT (or OPENSUBTITLES_USER_AGENT). Username/password optional depending on your OpenSubtitles setup.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_BASE_URL=https://api.opensubtitles.com/api/v1
OPENSUBTITLES_USER_AGENT=GlobalSubs/1.0
OPENSUBTITLES_XMLRPC_USERAGENT=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
DEBUG_OPENSUBTITLES=0

# OpenSubtitles.org (headless browser fetch; optional)
# When enabled, addon/internal ensure will try OpenSubtitles.org (via Playwright) before the shared resolver.
# Note: this can be slower and may fail if OpenSubtitles.org blocks headless traffic.
OPENSUBTITLES_ORG_HEADLESS=0
OPENSUBTITLES_ORG_USER_AGENT=GlobalSubs/1.0
DEBUG_OPENSUBTITLES_ORG=0

# SubDL (free-ish API but requires an account API key)
SUBDL_API_KEY=
SUBDL_BASE_URL=https://api.subdl.com/api/v1
SUBDL_DL_BASE_URL=https://dl.subdl.com/subtitle
SUBDL_USER_AGENT=GlobalSubs/1.0
SUBDL_MIN_INTERVAL_MS=350
DEBUG_SUBDL=0

# Podnapisi (HTML scraping; disabled by default)
PODNAPISI_ENABLED=0
PODNAPISI_BASE_URL=https://www.podnapisi.net
PODNAPISI_USER_AGENT=GlobalSubs/1.0
PODNAPISI_MIN_INTERVAL_MS=1200
PODNAPISI_COOKIE=

# Addic7ed (HTML scraping; disabled by default; may require login)
ADDIC7ED_ENABLED=0
ADDIC7ED_BASE_URL=https://www.addic7ed.com
ADDIC7ED_USER_AGENT=GlobalSubs/1.0
ADDIC7ED_MIN_INTERVAL_MS=1500

# TVsubtitles.net / Moviesubtitles.org (HTML scraping; disabled by default)
TVSUBTITLES_ENABLED=0
MOVIESUBTITLES_ENABLED=0
MOVIESUBTITLES_BASE_URL=https://www.moviesubtitles.org
MOVIESUBTITLES_USER_AGENT=GlobalSubs/1.0
MOVIESUBTITLES_MIN_INTERVAL_MS=1200
DEBUG_MOVIESUBTITLES=0

# Public Stremio Cinemeta (used for IMDb -> title/year lookup)
CINEMETA_BASE_URL=https://v3-cinemeta.strem.io

# Addon
ADDON_PORT=3012
ADDON_HOST=0.0.0.0
API_URL=http://localhost:3011
ADDON_PUBLIC_URL=http://127.0.0.1:3012

# Web
WEB_PORT=3010
NEXT_PUBLIC_WEB_URL=http://localhost:3010
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_ADDON_MANIFEST_URL=http://127.0.0.1:3012/manifest.json
# Google OAuth client ID for the frontend Google Sign-In button
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
