{
  "name": "stremio-ai-subs",
  "version": "1.0.0",
  "private": true,
  "description": "Stremio AI Subtitles - LLM-translated subtitles SaaS platform",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:no-scrapers": "pnpm --filter '!@stremio-ai-subs/scrapers' --parallel -r run dev",
    "dev:scrapers": "pnpm --filter @stremio-ai-subs/scrapers dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter e2e test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "demo": "pnpm --filter @stremio-ai-subs/api demo",
    "db:sync-to-prod": "bash scripts/sync-to-prod.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
