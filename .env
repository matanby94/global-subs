# Local development environment (do not commit)

# Database
DATABASE_URL=postgresql://stremio:stremio_dev@localhost:5466/stremio_ai_subs

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 Storage (MinIO in dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=stremio-ai-subs

# Ports (requested range 3010-3020)
WEB_PORT=3010
API_PORT=3011
ADDON_PORT=3012

# Binding (important for WSL)
ADDON_HOST=0.0.0.0

# API
API_HOST=0.0.0.0
JWT_SECRET=supersecretkey_change_in_production
CORS_ORIGIN=http://localhost:3010

# Addon -> API
API_URL=http://localhost:3011

# Web -> API
NEXT_PUBLIC_WEB_URL=http://localhost:3010
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_ADDON_MANIFEST_URL=http://127.0.0.1:3012/manifest.json

# Workers (set your real keys)
OPENAI_API_KEY=your-openai-key
GOOGLE_API_KEY=your-google-key
DEEPL_API_KEY=your-deepl-key
