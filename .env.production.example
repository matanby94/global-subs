# .env.production — Local config for running analytics agent against production
# Copy this to .env.production and fill in the values.
# This file is gitignored and NEVER committed.

# ── Production Postgres credentials (used via SSH tunnel) ──
PROD_PG_USER=stremio
PROD_PG_PASSWORD=<production-postgres-password>
PROD_PG_DB=stremio_ai_subs

# ── Umami (public URL for API access) ──
UMAMI_API_URL=https://analytics.globalsubs-ai.com
UMAMI_API_TOKEN=<from-umami-settings-api-create-token>
NEXT_PUBLIC_UMAMI_WEBSITE_ID=<from-umami-website-settings>

# ── LLM (gh models preferred, OpenAI as fallback) ──
ANALYTICS_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...  # Only needed if gh models run is unavailable
